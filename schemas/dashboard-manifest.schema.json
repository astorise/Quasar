{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quasar.local/schemas/dashboard-manifest.schema.json",
  "title": "Quasar Dashboard Manifest",
  "type": "object",
  "required": ["id", "title", "widgets"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "refreshSeconds": {
      "type": "integer",
      "minimum": 5,
      "default": 30
    },
    "widgets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "kind", "query"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string"
          },
          "kind": {
            "enum": ["timeseries", "funnel", "retention"]
          },
          "query": {
            "type": "object",
            "required": ["metric"],
            "additionalProperties": true,
            "properties": {
              "metric": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
