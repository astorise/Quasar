{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quasar.local/schemas/dashboard-manifest.schema.json",
  "title": "Quasar Dashboard Manifest",
  "type": "object",
  "required": ["id", "title", "widgets"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "refreshSeconds": {
      "type": "integer",
      "minimum": 5,
      "default": 30
    },
    "security": {
      "type": "object",
      "required": ["visibility"],
      "additionalProperties": false,
      "properties": {
        "visibility": {
          "enum": ["public", "authenticated", "restricted"],
          "default": "authenticated"
        },
        "allowed_roles": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true,
          "default": []
        },
        "enforced_filters": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          },
          "default": {}
        }
      }
    },
    "widgets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "kind", "query"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string"
          },
          "kind": {
            "enum": ["metric", "timeseries", "funnel", "retention"]
          },
          "title": {
            "type": "string"
          },
          "layout": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "columns": {
                "type": "integer",
                "minimum": 1,
                "maximum": 4
              },
              "rows": {
                "type": "integer",
                "minimum": 1,
                "maximum": 4
              }
            }
          },
          "query": {
            "type": "object",
            "required": ["metric"],
            "additionalProperties": true,
            "properties": {
              "metric": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
