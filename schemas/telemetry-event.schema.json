{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quasar.local/schemas/telemetry-event.schema.json",
  "title": "Quasar Telemetry Event",
  "type": "object",
  "required": ["distinct_id", "event", "timestamp", "properties"],
  "additionalProperties": false,
  "properties": {
    "distinct_id": {
      "type": "string",
      "minLength": 1
    },
    "event": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "region": {
      "type": "string"
    },
    "properties": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
