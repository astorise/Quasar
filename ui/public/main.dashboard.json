{
  "id": "main",
  "title": "Main Quasar Dashboard",
  "refreshSeconds": 30,
  "security": {
    "visibility": "public",
    "allowed_roles": [],
    "enforced_filters": {}
  },
  "widgets": [
    {
      "id": "active-users",
      "kind": "metric",
      "title": "Active Users",
      "layout": {
        "columns": 1,
        "rows": 1
      },
      "query": {
        "metric": "active_users"
      }
    },
    {
      "id": "signups-timeseries",
      "kind": "timeseries",
      "title": "Signups",
      "layout": {
        "columns": 3,
        "rows": 1
      },
      "query": {
        "metric": "signups",
        "type": "area"
      }
    }
  ]
}
